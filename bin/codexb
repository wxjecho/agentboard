#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd -- "${SCRIPT_DIR}/.." && pwd)"

BACKEND="${AGENTBOARD_BACKEND:-http://127.0.0.1:8000}"
PROJECT="${AGENTBOARD_PROJECT:-$(basename "$PWD")}"

exec python3 "${ROOT_DIR}/runner/codex_runner.py" \
  --backend "${BACKEND}" \
  --project "${PROJECT}" \
  --cwd "$PWD" \
  "$@"
